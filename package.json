{
  "name": "harhub",
  "version": "0.1.0-beta.3",
  "description": "Team AI harness management for skills, MCP, rules, and agent instructions.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RockChinQ/harhub.git"
  },
  "homepage": "https://github.com/RockChinQ/harhub#readme",
  "bugs": {
    "url": "https://github.com/RockChinQ/harhub/issues"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "harhub": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web && npm run build:docs",
    "build:server": "tsc -p tsconfig.node.json",
    "build:web": "vite build",
    "build:docs": "vitepress build docs",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "start": "node dist/server.js",
    "start:cli": "node dist/cli.js",
    "dev": "node scripts/dev.mjs",
    "dev:cloud": "node scripts/dev-minio.mjs",
    "dev:minio": "node scripts/dev-minio.mjs",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 5177",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 127.0.0.1 --port 4177",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "skills": "1.5.18",
    "tailwind-merge": "^3.3.1",
    "undici": "^7.28.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.8",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.21",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}
