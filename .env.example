PORT=3310
HARHUB_MAX_UPLOAD_BYTES=26214400

# Cloud-native state backend. Use Postgres-compatible hosted databases such as
# RDS, Cloud SQL, Neon, Supabase, or Crunchy Bridge.
HARHUB_DATABASE_URL=postgres://harhub:harhub@127.0.0.1:15432/harhub
# Set to "true" when the hosted database requires TLS and the provider manages
# the certificate chain.
HARHUB_DATABASE_SSL=false

# S3-compatible object storage for uploaded Skill zip packages.
HARHUB_S3_BUCKET=harhub-assets
HARHUB_S3_REGION=us-east-1
HARHUB_S3_ENDPOINT=http://127.0.0.1:9000
HARHUB_S3_FORCE_PATH_STYLE=true
HARHUB_S3_PREFIX=dev
HARHUB_S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/harhub-assets
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Public app URL used to build OAuth callback URLs and workspace invite links.
HARHUB_PUBLIC_URL=http://127.0.0.1:5176

# Email login codes and workspace invitation emails.
RESEND_API_KEY=
HARHUB_EMAIL_FROM=Harhub <onboarding@resend.dev>

# Optional OAuth providers. Callback URLs:
#   http://127.0.0.1:3310/api/auth/oauth/google/callback
#   http://127.0.0.1:3310/api/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
